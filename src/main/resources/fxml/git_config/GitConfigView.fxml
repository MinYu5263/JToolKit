<?xml version="1.0" encoding="UTF-8"?>

<?import atlantafx.base.controls.CustomTextField?>
<?import atlantafx.base.controls.ToggleSwitch?>
<?import com.minyu.jtoolkit.core.component.ConfigCard?>
<?import com.minyu.jtoolkit.core.component.ConfigGroup?>
<?import com.minyu.jtoolkit.core.component.EnhancedTextField?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>
<?import java.lang.String?>

<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minyu.jtoolkit.module.git_config.GitConfigController"
      spacing="10">

    <ConfigCard title="配置作用域">
        <HBox spacing="10">
            <ComboBox fx:id="scopeComboBox" HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnAddRepo" onAction="#onAddRepo" text="添加项目">
                <graphic>
                    <FontIcon iconLiteral="mdal-add"/>
                </graphic>
            </Button>
            <Button fx:id="btnRemoveRepo" onAction="#onRemoveRepo" text="移除">
                <graphic>
                    <FontIcon iconLiteral="mdal-delete"/>
                </graphic>
                <styleClass>
                    <String fx:value="danger"/>
                </styleClass>
            </Button>
        </HBox>
    </ConfigCard>

    <!-- 操作按钮行 -->
    <HBox spacing="10">
        <Button onAction="#onOpenSSHDialog" text="配置 SSH 密钥">
            <graphic>
                <FontIcon iconLiteral="mdmz-vpn_key"/>
            </graphic>
        </Button>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#onSaveConfig" text="保存修改">
            <styleClass>
                <String fx:value="accent"/>
            </styleClass>
            <graphic>
                <FontIcon iconLiteral="mdmz-save"/>
            </graphic>
        </Button>
    </HBox>

    <!-- 用户信息 -->
    <ConfigGroup title="用户信息" expanded="true">
        <ConfigCard title="用户名 (Name)" description="Git user.name">
            <EnhancedTextField fx:id="fieldName" mode="NONE" promptText="e.g. John Doe"/>
        </ConfigCard>
        <ConfigCard title="邮箱 (Email)" description="Git user.email">
            <EnhancedTextField fx:id="fieldEmail" mode="NONE" promptText="e.g. john@company.com"/>
        </ConfigCard>
    </ConfigGroup>

    <!-- 网络代理 -->
    <ConfigGroup title="网络代理" expanded="false">
        <ConfigCard title="启用代理" description="为 Git 配置 HTTP/HTTPS/SOCKS5 代理">
            <ToggleSwitch fx:id="toggleProxy" text="Disabled"/>
        </ConfigCard>
        <ConfigCard fx:id="proxyProtocolCard" title="代理协议" visible="false" managed="false">
            <ComboBox fx:id="choiceProtocol" prefWidth="150.0"/>
        </ConfigCard>
        <ConfigCard fx:id="proxyHostCard" title="代理地址" visible="false" managed="false">
            <EnhancedTextField fx:id="fieldProxyHost" mode="NONE" text="127.0.0.1:7890"/>
        </ConfigCard>
    </ConfigGroup>

    <Label text="所有配置"/>
    <HBox spacing="10">
        <CustomTextField fx:id="searchConfigField" promptText="搜索配置 Key 或 Value"
                         HBox.hgrow="ALWAYS">
            <left>
                <Label>
                    <graphic>
                        <FontIcon iconLiteral="mdmz-search" iconColor="#888888"/>
                    </graphic>
                    <padding>
                        <Insets left="8" right="5"/>
                    </padding>
                </Label>
            </left>
        </CustomTextField>
        <Button onAction="#onRefreshAllConfig" text="刷新">
            <graphic>
                <FontIcon iconLiteral="mdmz-refresh"/>
            </graphic>
        </Button>
        <Button onAction="#onAddRawConfig" text="添加">
            <graphic>
                <FontIcon iconLiteral="mdal-add"/>
            </graphic>
        </Button>
    </HBox>

    <TableView fx:id="allConfigTable" VBox.vgrow="ALWAYS" minHeight="350">
        <columns>
            <TableColumn fx:id="colKey" prefWidth="250" text="Key"/>
            <TableColumn fx:id="colValue" prefWidth="350" text="Value"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
    <Label styleClass="text-muted" text="双击行可编辑配置值"/>

</VBox>
