<?xml version="1.0" encoding="UTF-8"?>

<?import atlantafx.base.controls.Card?>
<?import atlantafx.base.controls.Tile?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21"
      fx:controller="com.minyu.jtoolkit.module.settings.SettingsController"
      spacing="10">

    <Label text="设置" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <VBox spacing="10.0">
        <Label text="外观"/>

        <Card>
            <body>
                <Tile title="主题" description="选择要使用的应用主题">
                    <action>
                        <ComboBox fx:id="themeCombo" prefWidth="200"/>
                    </action>
                </Tile>
            </body>
        </Card>
    </VBox>
</VBox>