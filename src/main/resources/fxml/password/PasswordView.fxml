<?xml version="1.0" encoding="UTF-8"?>

<?import atlantafx.base.controls.ToggleSwitch?>
<?import com.minyu.jtoolkit.core.component.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21">

    <Label text="配置"/>
    <ConfigGroup title="长度" expanded="false">
        <action>
            <Spinner/>
        </action>
        <ConfigCard title="小写字符" description="使用小写字符(abcdefghijkimnopqrstuwwxyz)">
            <action>
                <ToggleSwitch/>
            </action>
        </ConfigCard>
        <ConfigCard title="大写字符" description="使用大写字符(ABCDEFGHIJKLMNOPQRSTUVWXYZ)">
            <action>
                <ToggleSwitch/>
            </action>
        </ConfigCard>
        <ConfigCard title="数字字符" description="使用数字字符(0123456789)">
            <action>
                <ToggleSwitch/>
            </action>
        </ConfigCard>
        <ConfigCard title="特殊字符" description="使用特殊字符(!&quot;#$%&amp;&quot;)*+,-&quot;=&gt;?@]^}~)">
            <action>
                <ToggleSwitch/>
            </action>
        </ConfigCard>
    </ConfigGroup>

    <VBox spacing="10">
        <Label text="生成"/>
        <HBox spacing="5" alignment="CENTER_LEFT">
            <Button text="生成密码"/>
            <FontIcon iconLiteral="fth-x"/>
            <Spinner/>
        </HBox>
    </VBox>

    <EnhancedTextArea title="密码" mode="OUTPUT" VBox.vgrow="ALWAYS"/>
</VBox>