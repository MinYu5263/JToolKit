<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="500.0" prefWidth="700.0" spacing="20.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minyu.jtoolkit.module.password.PasswordController">

    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <VBox spacing="10.0">
        <Label text="生成结果 (Generated Password):" style="-fx-font-weight: bold;"/>
        <HBox spacing="10.0">
            <TextField fx:id="passwordField" editable="false" promptText="点击生成按钮..." HBox.hgrow="ALWAYS"/>
            <Button text="⟳ 生成" onAction="#onGenerate"/>
            <Button text="复制" onAction="#onCopy"/>
        </HBox>
        <Label fx:id="msgLabel" text="" textFill="green"/>
    </VBox>

    <Separator/>

    <GridPane hgap="20" vgap="15">
        <Label text="密码长度:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.columnSpan="2">
            <Slider fx:id="lengthSlider" min="4" max="64" value="16" blockIncrement="1" HBox.hgrow="ALWAYS"/>
            <Label fx:id="lengthLabel" text="16"/>
        </HBox>

        <Label text="字符包含:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <HBox spacing="15" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.columnSpan="2">
            <CheckBox fx:id="chkUpper" text="大写字母 (A-Z)" selected="true"/>
            <CheckBox fx:id="chkLower" text="小写字母 (a-z)" selected="true"/>
            <CheckBox fx:id="chkDigits" text="数字 (0-9)" selected="true"/>
            <CheckBox fx:id="chkSpecial" text="特殊字符 (!@#...)" selected="true"/>
        </HBox>

        <Label text="排除字符:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="excludeField" promptText="例如: i l 1 L o 0 O" GridPane.columnIndex="1" GridPane.rowIndex="2" HBox.hgrow="ALWAYS"/>
        <Label text="(输入不想出现的字符)" textFill="grey" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
    </GridPane>

    <Region VBox.vgrow="ALWAYS"/>

    <Label text="* 本工具使用 Java SecureRandom 生成强随机数，生成的密码不进行任何网络传输。"
           textFill="grey" wrapText="true"/>

</VBox>