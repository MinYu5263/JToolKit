<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox fx:id="root" alignment="CENTER" spacing="10.0"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minyu.jtoolkit.module.about.AboutController">

    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <ImageView fx:id="appLogo" pickOnBounds="true" preserveRatio="true">
        <VBox.margin>
            <Insets bottom="10.0" />
        </VBox.margin>
    </ImageView>

    <Label text="JToolKit" styleClass="title-1" />
    <Label fx:id="versionLabel" text="Version 1.0.0" styleClass="text-muted,text-small" />

    <Separator maxWidth="300.0">
        <VBox.margin>
            <Insets top="20.0" bottom="20.0"/>
        </VBox.margin>
    </Separator>

    <Label text="A comprehensive developer utility toolkit." styleClass="text-body" />
    <Label text="Designed for efficiency and elegance." styleClass="text-muted" />

    <HBox alignment="CENTER" spacing="20.0">
        <VBox.margin>
            <Insets top="20.0" />
        </VBox.margin>

        <Button text="GitHub" onAction="#openGithub">
            <graphic>
                <FontIcon iconLiteral="mdal-code" />
            </graphic>
        </Button>

        <Button text="Website" onAction="#openWebsite">
            <graphic>
                <FontIcon iconLiteral="mdmz-public" />
            </graphic>
        </Button>
    </HBox>

    <VBox alignment="CENTER" spacing="5.0">
        <VBox.margin>
            <Insets top="40.0" />
        </VBox.margin>
        <Label fx:id="systemInfoLabel" text="System Info" styleClass="text-caption,text-muted" />
        <Label text="© 2025 Minyu. All rights reserved." styleClass="text-caption,text-muted" />
    </VBox>

</VBox>