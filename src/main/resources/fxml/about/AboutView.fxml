<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox fx:id="root" alignment="CENTER" spacing="12.0"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minyu.jtoolkit.module.about.AboutController">

    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <ImageView fx:id="appLogo" pickOnBounds="true" preserveRatio="true">
        <VBox.margin>
            <Insets bottom="8.0" />
        </VBox.margin>
    </ImageView>

    <Label text="JToolKit" style="-fx-font-size: 26px; -fx-font-weight: bold;" />
    <Label fx:id="versionLabel" text="版本：1.0-SNAPSHOT" />
    <Label text="一个简单顺手的桌面开发工具箱。" wrapText="true" />

    <Button text="项目地址" onAction="#openGithub">
        <VBox.margin>
            <Insets top="12.0" />
        </VBox.margin>
        <graphic>
            <FontIcon iconLiteral="mdal-code" />
        </graphic>
    </Button>

</VBox>
