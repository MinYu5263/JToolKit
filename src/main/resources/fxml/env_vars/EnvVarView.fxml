<?xml version="1.0" encoding="UTF-8"?>

<?import atlantafx.base.controls.CustomTextField?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>
<?import java.lang.String?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minyu.jtoolkit.module.env_vars.EnvVarController"
      spacing="10">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

        <Tab text="用户变量 (User)">
            <VBox spacing="10">
                <padding>
                    <Insets top="10" right="5" bottom="5" left="5"/>
                </padding>

                <HBox spacing="10">
                    <CustomTextField fx:id="userSearchField" promptText="搜索变量名或值"
                                     HBox.hgrow="ALWAYS">
                        <left>
                            <Label>
                                <graphic>
                                    <FontIcon iconLiteral="mdmz-search" iconColor="#888888"/>
                                </graphic>
                                <padding>
                                    <Insets left="8" right="5"/>
                                </padding>
                            </Label>
                        </left>
                    </CustomTextField>
                    <Button onAction="#onRefreshUser" text="刷新">
                        <graphic>
                            <FontIcon iconLiteral="mdmz-refresh"/>
                        </graphic>
                    </Button>
                    <Button fx:id="btnAddUser" onAction="#onAddUserVar" text="新建">
                        <graphic>
                            <FontIcon iconLiteral="mdal-add"/>
                        </graphic>
                    </Button>
                </HBox>

                <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="userKeyCol" text="变量名 (Variable)" prefWidth="200"/>
                        <TableColumn fx:id="userValueCol" text="变量值 (Value)" prefWidth="400"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <HBox spacing="10">
                    <Button fx:id="btnEditUser" text="编辑" onAction="#onEditUserVar"/>
                    <Button fx:id="btnDelUser" text="删除" onAction="#onDeleteUserVar">
                        <styleClass>
                            <String fx:value="danger"/>
                        </styleClass>
                    </Button>
                </HBox>
            </VBox>
        </Tab>

        <Tab text="系统变量 (System)">
            <VBox spacing="10">
                <padding>
                    <Insets top="10" right="5" bottom="5" left="5"/>
                </padding>

                <HBox spacing="10">
                    <CustomTextField fx:id="sysSearchField" promptText="搜索变量名或值"
                                     HBox.hgrow="ALWAYS">
                        <left>
                            <Label>
                                <graphic>
                                    <FontIcon iconLiteral="mdmz-search" iconColor="#888888"/>
                                </graphic>
                                <padding>
                                    <Insets left="8" right="5"/>
                                </padding>
                            </Label>
                        </left>
                    </CustomTextField>
                    <Button onAction="#onRefreshSys" text="刷新">
                        <graphic>
                            <FontIcon iconLiteral="mdmz-refresh"/>
                        </graphic>
                    </Button>
                    <Button fx:id="btnAddSys" onAction="#onAddSysVar" text="新建">
                        <graphic>
                            <FontIcon iconLiteral="mdal-add"/>
                        </graphic>
                    </Button>
                </HBox>

                <TableView fx:id="sysTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="sysKeyCol" text="变量名 (Variable)" prefWidth="200"/>
                        <TableColumn fx:id="sysValueCol" text="变量值 (Value)" prefWidth="400"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <HBox spacing="10">
                    <Button fx:id="btnEditSys" text="编辑" onAction="#onEditSysVar"/>
                    <Button fx:id="btnDelSys" text="删除" onAction="#onDeleteSysVar">
                        <styleClass>
                            <String fx:value="danger"/>
                        </styleClass>
                        <tooltip>
                            <Tooltip text="删除系统变量可能导致系统不稳定，请谨慎操作"/>
                        </tooltip>
                    </Button>
                </HBox>
            </VBox>
        </Tab>

    </TabPane>
</VBox>
