<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="10.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minyu.jtoolkit.module.env_vars.EnvVarController">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

        <Tab text="系统/JVM 变量查看">
            <VBox spacing="5.0">
                <padding><Insets top="5"/></padding>

                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField" promptText="搜索 Key 或 Value..." HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="typeCombo" prefWidth="150.0"/>
                    <Button text="刷新" onAction="#onRefresh"/>
                </HBox>

                <TableView fx:id="systemTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="sysKeyCol" text="变量名 (Key)" prefWidth="250"/>
                        <TableColumn fx:id="sysValueCol" text="变量值 (Value)" prefWidth="500"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </Tab>

        <Tab text="配置脚本生成器">
            <SplitPane dividerPositions="0.6" VBox.vgrow="ALWAYS">
                <VBox spacing="5.0">
                    <padding><Insets top="5" right="5" bottom="5" left="5"/></padding>
                    <ToolBar>
                        <Button text="+ 添加行" onAction="#onAddRow"/>
                        <Button text="- 删除选中" onAction="#onDeleteRow"/>
                        <Button text="清空" onAction="#onClearRows"/>
                    </ToolBar>
                    <TableView fx:id="generatorTable" VBox.vgrow="ALWAYS" editable="true">
                        <columns>
                            <TableColumn fx:id="genKeyCol" text="Key (双击编辑)" prefWidth="150"/>
                            <TableColumn fx:id="genValueCol" text="Value (双击编辑)" prefWidth="250"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <VBox spacing="5.0">
                    <padding><Insets top="5" left="5"/></padding>
                    <Label text="导出格式:"/>
                    <ChoiceBox fx:id="formatChoice" maxWidth="Infinity"/>
                    <TextArea fx:id="previewArea" VBox.vgrow="ALWAYS" editable="false" wrapText="true"
                              style="-fx-font-family: 'Consolas', 'Monospaced';"/>
                    <Button text="复制结果" maxWidth="Infinity" onAction="#onCopyResult"/>
                </VBox>
            </SplitPane>
        </Tab>
    </TabPane>
</VBox>