<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minyu.jtoolkit.module.env_vars.EnvVarController"
      spacing="10.0" prefHeight="600.0" prefWidth="800.0">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="环境变量" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Label fx:id="osInfoLabel" text="(Windows)" textFill="grey"/>

        <HBox HBox.hgrow="ALWAYS"/>

        <TextField fx:id="searchField" promptText="搜索变量名或值..." prefWidth="250"/>
        <Button text="刷新" onAction="#onRefreshAll"/>
    </HBox>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

        <Tab text="用户变量 (User)">
            <VBox spacing="5.0">
                <padding><Insets top="10" right="5" bottom="5" left="5"/></padding>
                <Label text="仅对当前用户生效" style="-fx-text-fill: #666; -fx-font-size: 11px;"/>

                <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="userKeyCol" text="变量名 (Variable)" prefWidth="200"/>
                        <TableColumn fx:id="userValueCol" text="变量值 (Value)" prefWidth="400"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <HBox spacing="10.0">
                    <Button fx:id="btnAddUser" text="新建" onAction="#onAddUserVar"/>
                    <Button fx:id="btnEditUser" text="编辑" onAction="#onEditUserVar"/>
                    <Button fx:id="btnDelUser" text="删除" onAction="#onDeleteUserVar">
                        <styleClass><String fx:value="danger"/></styleClass>
                    </Button>
                </HBox>
            </VBox>
        </Tab>

        <Tab text="系统变量 (System)">
            <VBox spacing="5.0">
                <padding><Insets top="10" right="5" bottom="5" left="5"/></padding>
                <Label text="对所有用户生效 (需要管理员权限)" style="-fx-text-fill: #666; -fx-font-size: 11px;"/>

                <TableView fx:id="sysTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="sysKeyCol" text="变量名 (Variable)" prefWidth="200"/>
                        <TableColumn fx:id="sysValueCol" text="变量值 (Value)" prefWidth="400"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <HBox spacing="10.0">
                    <Button fx:id="btnAddSys" text="新建" onAction="#onAddSysVar"/>
                    <Button fx:id="btnEditSys" text="编辑" onAction="#onEditSysVar"/>
                    <Button fx:id="btnDelSys" text="删除" onAction="#onDeleteSysVar">
                        <styleClass><String fx:value="danger"/></styleClass>
                        <tooltip><Tooltip text="删除系统变量可能导致系统不稳定，请谨慎操作"/></tooltip>
                    </Button>
                </HBox>
            </VBox>
        </Tab>

    </TabPane>
</VBox>