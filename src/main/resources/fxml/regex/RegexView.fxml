<?xml version="1.0" encoding="UTF-8"?>

<?import atlantafx.base.controls.*?>
<?import com.minyu.jtoolkit.core.component.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.TextFlow?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minyu.jtoolkit.module.regex.RegexController"
      spacing="10">

    <ConfigGroup title="匹配选项 (Options)" expanded="false">
        <ConfigCard title="全部匹配 (Global)" description="查找文本中的所有匹配项">
            <ToggleSwitch fx:id="swGlobal" selected="true"/>
        </ConfigCard>
        <ConfigCard title="忽略大小写 (Case Insensitive)" description="启用 Pattern.CASE_INSENSITIVE">
            <ToggleSwitch fx:id="swIgnoreCase"/>
        </ConfigCard>
        <ConfigCard title="多行模式 (Multiline)" description="^ 和 $ 匹配每一行的开头和结尾">
            <ToggleSwitch fx:id="swMultiline"/>
        </ConfigCard>
        <ConfigCard title="单行模式 (DotAll)" description="点 (.) 匹配所有字符，包括换行符">
            <ToggleSwitch fx:id="swDotAll"/>
        </ConfigCard>
        <ConfigCard title="忽略空白符 (Comments)" description="允许正则中使用空格和注释">
            <ToggleSwitch fx:id="swComments"/>
        </ConfigCard>
        <ConfigCard title="Unicode 支持" description="启用 Unicode 字符类">
            <ToggleSwitch fx:id="swUnicode"/>
        </ConfigCard>
        <ConfigCard title="规范等价 (Canon Eq)" description="考虑 Unicode 规范等价性">
            <ToggleSwitch fx:id="swCanonEq"/>
        </ConfigCard>
    </ConfigGroup>

    <VBox spacing="8.0">
        <Label text="正则表达式 (Regular Expression)" styleClass="title-4"/>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="regexField" promptText="例如: \w+([-+.]\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*"
                       HBox.hgrow="ALWAYS"
                       style="-fx-font-family: 'JetBrains Mono', 'Consolas', 'Monospaced'; -fx-font-size: 14px;"/>

            <ComboBox fx:id="templateCombo" promptText="常用模板" prefWidth="160"/>
        </HBox>

        <Label fx:id="statusLabel" text="Ready" style="-fx-text-fill: -color-fg-muted;">
            <graphic>
                <FontIcon iconLiteral="mdal-info"/>
            </graphic>
        </Label>
    </VBox>

    <VBox spacing="8.0" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="文本内容 (Text)" styleClass="title-4"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="matchCountLabel" text="0 matches"
                   style="-fx-font-weight: bold; -fx-text-fill: -color-accent-fg;"/>
        </HBox>

        <StackPane VBox.vgrow="ALWAYS" alignment="TOP_RIGHT">

            <TextArea fx:id="sourceTextArea" promptText="在此输入或粘贴文本" wrapText="false"
                      style="-fx-font-family: 'JetBrains Mono', 'Consolas', 'Monospaced'; -fx-font-size: 14px;"/>

            <ScrollPane fx:id="highlightScroll" fitToWidth="true" fitToHeight="true" visible="false"
                        style="-fx-background-color: -color-bg-default; -fx-border-color: -color-border-default; -fx-border-radius: 4;">
                <TextFlow fx:id="highlightTextFlow"
                          style="-fx-padding: 8; -fx-background-color: -color-bg-default;">
                </TextFlow>
            </ScrollPane>

            <ToggleButton fx:id="btnToggleView" text="预览高亮" selected="false" styleClass="small">
                <graphic>
                    <FontIcon iconLiteral="mdmz-visibility"/>
                </graphic>
                <tooltip>
                    <Tooltip text="切换 编辑/高亮 模式"/>
                </tooltip>
                <StackPane.margin>
                    <Insets top="10" right="20"/>
                </StackPane.margin>
            </ToggleButton>
        </StackPane>
    </VBox>

</VBox>