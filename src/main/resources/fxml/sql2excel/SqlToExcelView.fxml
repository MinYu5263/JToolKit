<?xml version="1.0" encoding="UTF-8"?>

<?import com.minyu.jtoolkit.core.component.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minyu.jtoolkit.module.sql2excel.SqlToExcelController"
      spacing="10"
      styleClass="sql2excel">

<!--    <Label text="数据库连接"/>-->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="数据库连接:" minWidth="-Infinity"/>
        <ComboBox fx:id="profileCombo" promptText="请选择或创建连接" prefWidth="160" minWidth="-Infinity"/>
        <Button text="管理连接" onAction="#onManageConnections" minWidth="-Infinity"/>
        <Separator orientation="VERTICAL"/>
        <Label text="选择数据库:" minWidth="-Infinity"/>
        <ComboBox fx:id="databaseCombo" promptText="等待连接" prefWidth="160" editable="true" minWidth="-Infinity"/>
        <Button fx:id="btnRefreshDb" styleClass="button-icon" onAction="#onRefreshDatabases" minWidth="-Infinity">
            <graphic>
                <FontIcon iconLiteral="fth-refresh-cw"/>
            </graphic>
            <tooltip>
                <Tooltip text="刷新数据库列表"/>
            </tooltip>
        </Button>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="connStatusLabel" text="未连接" styleClass="status-label" maxWidth="250"/>
    </HBox>

    <EnhancedTextArea fx:id="sqlArea" title="SQL 查询语句" areaStyle="code-area"
                      promptText="支持多条 SQL（分号分隔），例如:&#10;SELECT * FROM users;&#10;SELECT * FROM orders;"
                      wrapText="true" VBox.vgrow="ALWAYS" minHeight="200"
                      mode="INPUT"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="运行预览 (前50行)" onAction="#onPreviewCurrent"/>
        <Label fx:id="previewStatusLabel" text="准备就绪" styleClass="status-label"/>
    </HBox>

    <TabPane fx:id="previewTabPane" VBox.vgrow="ALWAYS" minHeight="200" tabClosingPolicy="UNAVAILABLE"
             styleClass="preview-tabs"/>

    <Button text="批量导出所有到 Excel" onAction="#onBatchExport" maxWidth="Infinity"
            styleClass="export-button"/>
</VBox>
